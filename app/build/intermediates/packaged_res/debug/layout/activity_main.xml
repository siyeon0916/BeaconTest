<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F1117"
    android:padding="16dp">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp"
        android:paddingTop="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Beacon Scanner"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#F0F2F8"/>
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 대기중"
            android:textSize="13sp"
            android:textColor="#6B7280"/>
    </LinearLayout>

    <!-- 통계 카드 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1A1D2E"
            android:padding="14dp"
            android:gravity="center">
            <TextView
                android:id="@+id/tvCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#60A5FA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="발견된 기기"
                android:textSize="12sp"
                android:textColor="#6B7280"/>
        </LinearLayout>
        <View android:layout_width="8dp" android:layout_height="1dp"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1A1D2E"
            android:padding="14dp"
            android:gravity="center">
            <TextView
                android:id="@+id/tvStrong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#4ADE80"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="강한 신호 (>-70)"
                android:textSize="12sp"
                android:textColor="#6B7280"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <Button
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="스캔 시작"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3B82F6"/>
        <View android:layout_width="8dp" android:layout_height="1dp"/>
        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="스캔 정지"
            android:enabled="false"
            android:backgroundTint="#374151"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="#1A1D2E"
        android:padding="12dp"
        android:text="위치 추정 대기 중..."
        android:textSize="13sp"
        android:textColor="#6B7280"
        android:fontFamily="monospace"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="감지된 비콘"
        android:textSize="12sp"
        android:textColor="#6B7280"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="스캔 시작 버튼을 눌러 비콘을 탐색하세요"
        android:textSize="14sp"
        android:textColor="#4B5563"
        android:gravity="center"
        android:paddingTop="40dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
